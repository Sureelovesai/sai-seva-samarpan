generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?  // null if OAuth-only later
  firstName    String?
  lastName     String?
  name         String?  // legacy / display
  location      String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  blogPosts    BlogPost[]
  blogAnalyticsReports BlogAnalyticsReport[]
  communityOutreachProfile CommunityOutreachProfile?

  @@index([email])
}

enum CommunityOutreachStatus {
  PENDING
  APPROVED
  REJECTED
}

/// Organization profile for Community Outreach (reviewed by admins / regional coordinators).
model CommunityOutreachProfile {
  id               String                   @id @default(cuid())
  userId           String                   @unique
  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationName String
  /// Optional logo / company image (URL or uploaded path); shown on Partner Organizations.
  logoUrl          String?
  description      String?                  @db.Text
  city             String
  contactPhone     String?
  website          String?
  status           CommunityOutreachStatus  @default(PENDING)
  submittedAt      DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  reviewedAt       DateTime?
  reviewerNote     String?                  @db.VarChar(500)

  @@index([status])
  @@index([city])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

enum BlogPostStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model BlogPost {
  id        String         @id @default(cuid())
  title     String
  content   String         @db.Text
  imageUrl  String?
  /// Optional extra media: [{ "url": "https://drive.google.com/...", "caption": "..." }] — Google Drive/Docs only; set per post by authors.
  driveMediaLinks Json?
  /// Per-post Google Drive folder (created by server when GOOGLE_DRIVE_* env is set). Uploads and curated links for this story only.
  driveFolderId String?
  section   String         // e.g. "Seva in Action", "SSSE & Sai Youth Corner"
  /// Sai center / group city (for regional blog analytics reports). Optional.
  centerCity String?
  /// Date of the seva / story (as entered by the poster).
  sevaDate  DateTime?
  /// Seva category (same list as Find Seva / activities).
  sevaCategory String?
  posterEmail String?
  posterPhone String?
  authorId  String?
  author    User?          @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName String?       // display name for guest or fallback
  status    BlogPostStatus @default(APPROVED) // APPROVED = visible; new posts created as PENDING_APPROVAL
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  reactions BlogPostReaction[]
  comments  BlogPostComment[]

  @@index([section])
  @@index([createdAt])
  @@index([status])
  @@index([centerCity])
  @@index([sevaCategory])
}

/// AI-generated narrative report over a set of approved blog posts (filters + word target).
model BlogAnalyticsReport {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  createdById      String?
  createdBy        User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  dateFrom         DateTime
  dateTo           DateTime
  centerFilter     String?
  regionFilter     String?
  /// When set, blog posts (and activity list) were scoped to this seva category.
  sevaCategoryFilter String?
  targetWordCount  Int      @default(500)
  userInstructions String?  @db.Text
  generatedBody    String   @db.Text
  editedBody       String?  @db.Text
  /// JSON array of BlogPost ids included in this report
  sourcePostIds    Json
  reportTitle      String?

  @@index([createdAt])
  @@index([createdById])
}

model BlogPostComment {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  content   String   @db.VarChar(500)
  authorName String?
  createdAt DateTime @default(now())

  @@index([postId])
}

enum BlogReactionType {
  LIKE
  DISLIKE
  EMOJI
}

model BlogPostReaction {
  id             String           @id @default(cuid())
  postId         String
  post           BlogPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  userIdentifier String           // userId (if logged in) or guest cookie id
  type           BlogReactionType
  emojiCode      String?           // for EMOJI type, e.g. "👍"
  createdAt      DateTime         @default(now())

  @@unique([postId, userIdentifier])
  @@index([postId])
}

enum AppRole {
  ADMIN
  BLOG_ADMIN
  VOLUNTEER
  SEVA_COORDINATOR
}

model RoleAssignment {
  id        String   @id @default(cuid())
  email     String
  role      AppRole
  cities    String?  // Comma-separated cities for SEVA_COORDINATOR (e.g. "Charlotte, Raleigh")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, role])
  @@index([email])
  @@index([role])
}

model SevaActivity {
  id               String             @id @default(cuid())
  title            String
  category         String
  city             String
  /// Partner / org name (Community Outreach); shown on Find Community Activity.
  organizationName String?
  /// When true, activity is listed only on Find Community Activity, not on Find Seva / home featured / public calendar.
  listedAsCommunityOutreach Boolean @default(false)
  isActive         Boolean            @default(true)
  isFeatured       Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  address          String?
  capacity         Int?
  coordinatorEmail String?
  coordinatorName  String?
  coordinatorPhone String?
  description      String?
  endDate          DateTime?
  endTime          String?
  imageUrl         String?
  locationName     String?
  startDate        DateTime?
  startTime        String?
  durationHours   Float?              // Duration in hours (e.g. 1.5 = 1hr 30min); used for Total Hours Served
  reminderSentAt  DateTime?           // When the 24h-before reminder was sent (volunteers + coordinator)
  status           SevaActivityStatus @default(DRAFT)
  signups          SevaSignup[]
  contributionItems SevaContributionItem[]

  @@index([listedAsCommunityOutreach])
}

/// Items volunteers can sign up to bring (e.g. food drive, supplies).
model SevaContributionItem {
  id           String                   @id @default(cuid())
  activityId   String
  activity     SevaActivity             @relation(fields: [activityId], references: [id], onDelete: Cascade)
  name         String
  category     String                   @default("")
  neededLabel  String                   @default("") // display e.g. "10 lbs"
  maxQuantity  Int                      @default(1) // total units / slots
  sortOrder    Int                      @default(0)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  claims       SevaContributionClaim[]

  @@index([activityId])
}

model SevaContributionClaim {
  id            String                        @id @default(cuid())
  itemId        String
  item          SevaContributionItem          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantity      Int                           @default(1)
  volunteerName String
  email         String
  phone         String?
  status        SevaContributionClaimStatus   @default(CONFIRMED)
  createdAt     DateTime                      @default(now())

  @@index([itemId])
  @@index([email])
}

enum SevaContributionClaimStatus {
  CONFIRMED
  CANCELLED
}

model SevaSignup {
  id            String           @id @default(cuid())
  activityId    String
  activity      SevaActivity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  volunteerName String
  email         String
  phone         String?
  adultsCount   Int              @default(1) // adults including the primary volunteer
  kidsCount     Int              @default(0) // number of children
  status        SevaSignupStatus @default(PENDING)
  comment       String?          // optional note from volunteer (e.g. from My Seva Dashboard)
  createdAt     DateTime        @default(now())

  @@index([activityId])
}

model LoggedHours {
  id               String   @id @default(cuid())
  volunteerName    String
  email            String?  // optional: set when user is logged in, for My Seva Dashboard
  location         String?
  activityCategory String   // e.g. Food Service, Medical Service, Other
  hours            Float
  date             DateTime // date of service
  comments         String?
  createdAt        DateTime @default(now())

  @@index([date])
  @@index([email])
}

enum SevaSignupStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SevaActivityStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}
