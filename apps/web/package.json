{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "./prisma/schema.prisma"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "postinstall": "node scripts/ensure-db-url-and-generate.cjs --generate-only",
    "build": "node scripts/ensure-db-url-and-generate.cjs && next build",
    "vercel-build": "node scripts/ensure-db-url-and-generate.cjs && next build",
    "start": "next start",
    "lint": "eslint",
    "prisma:generate": "prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=./prisma/schema.prisma",
    "reset-seva-activities": "node scripts/reset-all-data.js"
  },
  "dependencies": {
    "@prisma/adapter-neon": "^6.15.0",
    "@prisma/client": "^6.15.0",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@vercel/blob": "^0.25.1",
    "exceljs": "^4.4.0",
    "googleapis": "^144.0.0",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^3.0.1",
    "next": "16.1.6",
    "prisma": "^6.15.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-quill": "^2.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
