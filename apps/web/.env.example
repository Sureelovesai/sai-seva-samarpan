# Database (required for Prisma)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Neon — runtime URL should use the POOLER host (…-pooler… in the hostname) so the app shares
# connections and avoids P2037 “too many connections”. Use DIRECT_URL (non-pooler) only for migrations.
# See: Neon dashboard → Connection details → pooled vs direct strings.

# Neon — migrations (fixes P1017 when DATABASE_URL uses the pooler):
# In Neon: Connection details → copy "Connection string" for the **direct** host (no `-pooler`).
# Set the same variable on Vercel (or your host) if you run `prisma migrate deploy` in CI.
# If DATABASE_URL is already direct, omit this; prisma.config falls back to DATABASE_URL.
# DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# -----------------------------------------------------------------------------
# Blog analytics reports (OpenAI) — required to generate AI reports on /admin/blog-reports
# Create a key: https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
# Optional; default is gpt-4o-mini (good balance of cost and quality)
# OPENAI_MODEL=gpt-4o-mini
# Help chatbot (floating widget) uses the same key; optional model override:
# OPENAI_CHAT_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# Email (Resend) – required to send to volunteers and coordinators
# See docs/RESEND-SETUP.md for domain verification so you can send to anyone.
# -----------------------------------------------------------------------------
EMAIL_ENABLED=true
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Use your verified Resend domain (e.g. subdomain send.srisathyasaigcf.org)
EMAIL_FROM="Seva Portal <noreply@send.srisathyasaigcf.org>"

# Portal /events emails only (RSVP, 24h reminders) — use Charlotte Sai Center domain, not the global Seva from.
# Default in code: Charlotte Sai Center Events <events@charlottesaicenter.org> — verify charlottesaicenter.org in Resend.
# EMAIL_FROM_EVENTS="Charlotte Sai Center Events <events@charlottesaicenter.org>"

# Optional: protect 24h reminder cron
# CRON_SECRET=your-secret-string

# App URL used in emails (e.g. "Open Admin Dashboard" link). Set in production so links point to your site, not localhost.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Portal /events times are always US Eastern (America/New_York) with "EST" in copy — no env needed.
# Optional: IANA zone for interpreting Seva activity startDate+startTime in 24h reminder logic
# (default America/New_York). Does not change /events display.
# NEXT_PUBLIC_EVENT_TIMEZONE=America/New_York
# Override seva reminders only: SEVA_REMINDER_TIMEZONE=America/Los_Angeles

# -----------------------------------------------------------------------------
# Seva blog — Cloudflare R2 (S3) for "Upload more media" on create/edit post
# Bucket CORS: allow your site origin, methods GET/PUT/HEAD, headers Content-Type, etc.
# See Cloudflare R2 dashboard → bucket → CORS.
# Public URL must match what you set as r2.dev custom domain or public R2 URL.
# -----------------------------------------------------------------------------
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=https://your-bucket.r2.dev
# Client-side link validation (must use the same public origin as R2_PUBLIC_BASE_URL):
# NEXT_PUBLIC_R2_PUBLIC_BASE_URL=https://your-bucket.r2.dev
